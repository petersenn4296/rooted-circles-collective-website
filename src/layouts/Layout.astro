---
import "../styles/global.css";
import Navbar from "../components/NavBar";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

const { title = "Home" } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>
      {title === "Home" ? "Rooted Circles" : `Rooted Circles - ${title}`}
    </title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>

  <body class="min-h-screen flex flex-col bg-tan text-evergreen">
    <Navbar client:load transition:persist />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>
